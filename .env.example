# Frontend build-time config.
# The ws(s):// origin of the deployed signaling Worker.
# Local dev against `wrangler dev`:
#   VITE_SIGNALING_URL=ws://localhost:8787
# Production (after mapping the Worker to a custom domain, see README step 5):
#   VITE_SIGNALING_URL=wss://signal.swisshost.cc
VITE_SIGNALING_URL=ws://localhost:8787
